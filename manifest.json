{
  "manifest_version": 3,
  "name": "Lumi 译伴 — Claude 中文化",
  "version": "0.1.0",
  "description": "给 Claude 打一道光,让你看见中文。专为 claude.ai 与 claude.ai/design 维护的中文 UI 词表;只翻译界面,不动你的输入与 AI 输出。",
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "src/dictionary.js",
        "src/boundary.js",
        "src/translator.js",
        "src/content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
